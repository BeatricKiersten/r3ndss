# API Configuration
API_PORT=3001
NODE_ENV=development

# MySQL Configuration
# Optional single URL (overrides host/port/user/pass/db fields below)
# Example: mysql://user:pass@host:3306/dbname?ssl-mode=REQUIRED
MYSQL_URL=

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=zenius
MYSQL_CONNECTION_LIMIT=10
MYSQL_AUTO_CREATE_DATABASE=true
MYSQL_SSL=false
MYSQL_SSL_REJECT_UNAUTHORIZED=true

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Backup Settings
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=1073741824

# Voe.sx Configuration
VOE_API_KEY=your_voe_api_key

# Catbox Configuration
CATBOX_USER_HASH=your_catbox_user_hash

# SeekStreaming Configuration
SEEK_API_KEY=your_seek_api_key
SEEK_API_BASE_URL=https://seekstreaming.com/api
SEEK_DOWNLOAD_BASE_URL=https://suo.emergingtechhubonline.store
SEEK_DOWNLOAD_VARIANT_PATH=v4/k5
SEEK_DOWNLOAD_PLAYLIST=index-f1-v1-a1.txt
SEEK_DOWNLOAD_FALLBACK_BASE_URLS=https://s9m.technologyevolution.space
SEEK_DOWNLOAD_FALLBACK_VARIANT_PATHS=v4/us
SEEK_DOWNLOAD_COOKIE=

# Rclone Configuration
RCLONE_BIN=rclone

# Logging (lightweight)
DEBUG_HTTP_VERBOSE=false
